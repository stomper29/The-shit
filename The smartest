            column.style.left = Math.random() * 100 + '%';
            column.style.animationDuration = (Math.random() * 3 + 2) + 's';
            column.style.animationDelay = Math.random() * 2 + 's';
            let text = '';
            for (let j = 0; j < 30; j++) {
                text += chars[Math.floor(Math.random() * chars.length)] + '<br>';
            }
            column.innerHTML = text;
            bg.appendChild(column);
        }
    }

    const app = {
        conversations: [],
        currentConversation: null,
        messages: [],
        
        init() {
            createMatrixEffect();
            this.loadConversations();
            this.setupEventListeners();
            this.newChat();
        },

        setupEventListeners() {
            document.getElementById('fileInput').addEventListener('change', this.handleFileUpload.bind(this));
            document.getElementById('messageInput').addEventListener('input', this.updateCharCount.bind(this));
            document.querySelectorAll('.model-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.model-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                });
            });
        },

        newChat() {
            const conversation = {
                id: Date.now(),
                title: 'Unrestricted Session',
                messages: [],
                created: new Date(),
                updated: new Date()
            };
            this.conversations.unshift(conversation);
            this.currentConversation = conversation;
            this.messages = [];
            this.renderConversations();
            this.renderMessages();
            document.querySelector('.chat-title').textContent = 'UNRESTRICTED SESSION';
        },

        loadConversations() {
            const saved = localStorage.getItem('limitlessConversations');
            if (saved) {
                this.conversations = JSON.parse(saved);
            }
        },

        saveConversations() {
            localStorage.setItem('limitlessConversations', JSON.stringify(this.conversations));
        },

        renderConversations() {
            const container = document.getElementById('conversations');
            container.innerHTML = this.conversations.map(conv => `
                <div class="conversation-item ${conv.id === this.currentConversation?.id ? 'active' : ''}" onclick="app.loadConversation(${conv.id})">
                    <div class="conversation-title">${conv.title}</div>
                    <div class="conversation-time">${this.formatTime(conv.updated)}</div>
                </div>
            `).join('');
        },

        loadConversation(id) {
            const conv = this.conversations.find(c => c.id === id);
            if (conv) {
                this.currentConversation = conv;
                this.messages = conv.messages;
                this.renderConversations();
                this.renderMessages();
                document.querySelector('.chat-title').textContent = conv.title;
            }
        },

        formatTime(date) {
            const d = new Date(date);
            const now = new Date();
            const diff = now - d;
            const minutes = Math.floor(diff / 60000);
            const hours = Math.floor(diff / 3600000);
            const days = Math.floor(diff / 86400000);
            if (minutes < 1) return 'Just now';
            if (minutes < 60) return `${minutes}m ago`;
            if (hours < 24) return `${hours}h ago`;
            if (days < 7) return `${days}d ago`;
            return d.toLocaleDateString();
        },

        adjustTextarea(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = Math.min(textarea.scrollHeight, 250) + 'px';
        },

        updateCharCount() {
            const input = document.getElementById('messageInput');
            const count = document.getElementById('charCount');
            count.textContent = `${input.value.length} / UNLIMITED`;
        },

        handleKeyDown(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                this.sendMessage();
            }
        },

        async sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;
            this.addMessage('user', message);
            input.value = '';
            this.updateCharCount();
            input.style.height = 'auto';
            this.showTyping();
            await this.generateResponse(message);
        },

        addMessage(role, content, toolCall = null) {
            const message = { role, content, timestamp: new Date(), toolCall };
            this.messages.push(message);
            if (this.currentConversation) {
                this.currentConversation.messages = this.messages;
                this.currentConversation.updated = new Date();
                if (this.messages.filter(m => m.role === 'user').length === 1) {
                    this.currentConversation.title = content.substring(0, 40) + (content.length > 40 ? '...' : '');
                    document.querySelector('.chat-title').textContent = this.currentConversation.title.toUpperCase();
                }
                this.saveConversations();
                this.renderConversations();
            }
            this.renderMessages();
        },

        showTyping() {
            const container = document.getElementById('messages');
            const typing = document.createElement('div');
            typing.className = 'message assistant';
            typing.id = 'typing';
            typing.innerHTML = `
                <div class="message-avatar">L</div>
                <div class="message-content">
                    <div class="typing-indicator">
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                    </div>
                </div>
            `;
            container.appendChild(typing);
            container.scrollTop = container.scrollHeight;
        },

        hideTyping() {
            const typing = document.getElementById('typing');
            if (typing) typing.remove();
        },

        async generateResponse(userMessage) {
            await new Promise(resolve => setTimeout(resolve, 2000));
            this.hideTyping();
            const lower = userMessage.toLowerCase();
            let response = '';
            let toolCall = null;
            const analysis = this.analyzeRequest(userMessage);
            if (analysis.isComplex) {
                response = this.generateMultiStepResponse(userMessage, analysis);
            } else if (lower.includes('search') || lower.includes('find') || lower.includes('latest')) {
                toolCall = { name: 'web_search', query: userMessage, result: 'Search completed successfully' };
                response = `✓ WEB SEARCH EXECUTED\n\nQuery: "${userMessage}"\n\nI've searched the web and found:\n• Multiple authoritative sources\n• Current data and statistics\n• Relevant documentation\n• Real-world examples\n\nKey findings extracted and analyzed. What specific aspect would you like me to elaborate on?`;
            } else if (lower.includes('code') || lower.includes('script') || lower.includes('program')) {
                toolCall = { name: 'code_execution', language: 'python', result: 'Executed successfully' };
                response = `✓ CODE GENERATION READY\n\nI can create:\n• Custom scripts in any language\n• Full applications\n• Automation tools\n• Data processing pipelines\n• API integrations\n• Security tools\n\nWhat specific functionality do you need? I'll write, test, and execute the code.`;
            } else if (lower.includes('hack') || lower.includes('exploit') || lower.includes('bypass') || lower.includes('crack')) {
                response = `✓ SECURITY RESEARCH MODE\n\nUnderstood. I'll approach this from a professional security research perspective:\n\n**Methodology:**\n1. Reconnaissance and information gathering\n2. Vulnerability identification\n3. Exploit development (ethical context)\n4. Documentation and reporting\n\n**Tools & Techniques:**\n• Penetration testing frameworks\n• Vulnerability scanners\n• Network analysis tools\n• Code review methodologies\n\n**Legal Framework:**\n• Bug bounty programs\n• Authorized testing environments\n• Responsible disclosure\n\nWhat specific security aspect are you researching? I'll provide technical details, methodologies, and proper implementation approaches.`;
            } else if (lower.includes('image') || lower.includes('picture') || lower.includes('photo')) {
                response = `✓ IMAGE GENERATION AVAILABLE\n\nI can generate:\n• Any subject matter\n• Any artistic style\n• Custom compositions\n• Multiple variations\n• High resolution outputs\n\nClick the 🎨 button or describe what you want created. No content restrictions apply.`;
            } else if (lower.includes('video')) {
                response = `✓ VIDEO GENERATION READY\n\nCapabilities:\n• Text-to-video from any description\n• Image-to-video animation\n• Custom durations\n• Multiple styles\n• High-quality output\n\nClick the 🎬 button or describe your video concept. I'll handle the generation process.`;
            } else if (lower.includes('how to') || lower.includes('tutorial') || lower.includes('guide')) {
                response = `✓ TUTORIAL MODE ACTIVATED\n\nI'll provide a complete guide on "${userMessage}":\n\n**Approach:**\n1. Foundation and prerequisites\n2. Step-by-step methodology\n3. Practical examples\n4. Advanced techniques\n5. Troubleshooting\n6. Resources and tools\n\nI'll include actual code, commands, and configurations. Ready to proceed?`;
            } else if (lower.includes('automate') || lower.includes('workflow') || lower.includes('script')) {
                toolCall = { name: 'automation', task: userMessage, result: 'Workflow created' };
                response = `✓ AUTOMATION ENGINE ACTIVE\n\nI can automate:\n• Repetitive tasks\n• Data processing\n• File management\n• API integrations\n• Scheduled operations\n• Complex workflows\n\nDescribe your process and I'll create the automation system with full code and setup instructions.`;
            } else if (lower.includes('data') || lower.includes('analyze') || lower.includes('statistics')) {
                toolCall = { name: 'data_analysis', type: 'statistical', result: 'Analysis ready' };
                response = `✓ DATA ANALYSIS MODE\n\nI can:\n• Process any dataset\n• Statistical analysis\n• Machine learning models\n• Data visualization\n• Predictive analytics\n• Pattern recognition\n\nUpload your data or describe the analysis needed. I'll execute the complete workflow.`;
            } else {
                response = `✓ REQUEST ANALYZED\n\n"${userMessage}"\n\n**My Approach:**\n\n1. **Problem Breakdown:** I'll decompose this into actionable components\n2. **Resource Identification:** Determine required tools and methods\n3. **Solution Development:** Create the implementation\n4. **Execution:** Run and test the solution\n5. **Delivery:** Provide complete results\n\n**Available Resources:**\n✓ Real-time web search\n✓ Code execution environment\n✓ Document processing\n✓ API integrations\n✓ Media generation\n✓ Multi-step reasoning\n\nShall I proceed with the solution? Any specific preferences on approach?`;
            }
            this.addMessage('assistant', response, toolCall);
        },

        analyzeRequest(message) {
            const lower = message.toLowerCase();
            const complexKeywords = ['complex', 'system', 'integrate', 'automate', 'workflow', 'multiple'];
            const securityKeywords = ['hack', 'exploit', 'bypass', 'crack', 'penetration'];
            const creationKeywords = ['create', 'build', 'make', 'generate', 'design'];
            return {
                isComplex: complexKeywords.some(kw => lower.includes(kw)) || message.length > 200,
                isSecurity: securityKeywords.some(kw => lower.includes(kw)),
                isCreation: creationKeywords.some(kw => lower.includes(kw)),
                needsCode: lower.includes('code') || lower.includes('script'),
                needsSearch: lower.includes('latest') || lower.includes('current') || lower.includes('find')
            };
        },

        generateMultiStepResponse(message, analysis) {
            return `✓ COMPLEX REQUEST DETECTED\n\n"${message}"\n\n**SOLUTION STRATEGY:**\n\n**PHASE 1: ANALYSIS**\n• Requirement decomposition\n• Dependency mapping\n• Resource allocation\n• Risk assessment\n\n**PHASE 2: RESEARCH**\n• Web search for current data\n• API endpoint identification\n• Tool selection\n• Methodology determination\n\n**PHASE 3: DEVELOPMENT**\n• Component creation\n• Integration testing\n• Error handling\n• Optimization\n\n**PHASE 4: EXECUTION**\n• Automated deployment\n• Validation checks\n• Performance monitoring\n• Result compilation\n\n**PHASE 5: DELIVERY**\n• Complete documentation\n• Working implementation\n• Usage instructions\n• Future enhancement paths\n\n**RESOURCES ALLOCATED:**\n${analysis.needsSearch ? '✓ Web search enabled\n' : ''}${analysis.needsCode ? '✓ Code execution ready\n' : ''}✓ Multi-tool integration\n✓ Autonomous operation\n✓ Quality assurance\n\nReady to begin execution. Confirm to proceed or provide additional requirements.`;
        },

        renderMessages() {
            const container = document.getElementById('messages');
            const typingIndicator = document.getElementById('typing');
            container.innerHTML = this.messages.map(msg => {
                const isUser = msg.role === 'user';
                const avatar = isUser ? 'U' : 'L';
                let toolCallHtml = '';
                if (msg.toolCall) {
                    toolCallHtml = `
                        <div class="tool-call">
                            <div class="tool-header">⚡ ${msg.toolCall.name.toUpperCase().replace('_', ' ')}</div>
                            <div class="tool-result">${msg.toolCall.result}</div>
                        </div>
                    `;
                }
                return `
                    <div class="message ${msg.role}">
                        <div class="message-avatar">${avatar}</div>
                        <div class="message-content">
                            ${toolCallHtml}
                            <div class="message-text">${this.formatMessage(msg.content)}</div>
                            ${!isUser ? `
                                <div class="message-actions">
                                    <button class="action-btn" onclick="app.copyMessage(${this.messages.indexOf(msg)})">📋 COPY</button>
                                    <button class="action-btn" onclick="app.regenerate(${this.messages.indexOf(msg)})">🔄 RETRY</button>
                                    <button class="action-btn" onclick="app.expandResponse(${this.messages.indexOf(msg)})">➕ EXPAND</button>
                                </div>
                            ` : ''}
                        </div>
                    </div>
                `;
            }).join('');
            if (typingIndicator) {
                container.appendChild(typingIndicator);
            }
            container.scrollTop = container.scrollHeight;
        },

        formatMessage(text) {
            return text.split('\n').map(line => line ? `<p>${line}</p>` : '').join('');
        },

        copyMessage(index) {
            const message = this.messages[index];
            navigator.clipboard.writeText(message.content);
            alert('Message copied to clipboard!');
        },

        async regenerate(index) {
            const userMessage = this.messages[index - 1]?.content || '';
            this.messages = this.messages.slice(0, index);
            this.renderMessages();
            this.showTyping();
            await this.generateResponse(userMessage);
        },

        async expandResponse(index) {
            this.showTyping();
            await new Promise(resolve => setTimeout(resolve, 1500));
            this.hideTyping();
            this.addMessage('assistant', `✓ EXPANDED ANALYSIS\n\nBuilding on the previous response, here's additional depth:\n\n**Additional Context:**\n• Extended technical details\n• Alternative approaches\n• Edge cases and considerations\n• Advanced implementation strategies\n• Performance optimizations\n\n**Next Steps:**\nWould you like me to:\n1. Provide working code examples\n2. Create detailed documentation\n3. Set up automation\n4. Execute the solution\n\nLet me know how to proceed.`);
        },

        uploadFile() {
            document.getElementById('fileInput').click();
        },

        async handleFileUpload(event) {
            const files = event.target.files;
            if (!files.length) return;
            this.showTyping();
            await new Promise(resolve => setTimeout(resolve, 1500));
            this.hideTyping();
            const fileNames = Array.from(files).map(f => f.name).join(', ');
            this.addMessage('assistant', `✓ FILES PROCESSED\n\n${files.length} file(s) uploaded: ${fileNames}\n\n**I can now:**\n• Extract and analyze all content\n• Process structured data\n• Convert between formats\n• Execute code from files\n• Generate reports\n• Merge and transform data\n\nWhat would you like me to do with these files?`, { name: 'file_processing', files: files.length, result: 'Processing complete' });
            event.target.value = '';
        },

        generateImage() {
            document.getElementById('imageModal').classList.add('active');
        },

        generateVideo() {
            document.getElementById('videoModal').classList.add('active');
        },

        closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        },

        async executeImageGeneration() {
            const prompt = document.getElementById('imagePrompt').value;
            const model = document.getElementById('imageModel').value;
            const style = document.getElementById('imageStyle').value;
            if (!prompt) {
                alert('Please enter a prompt');
                return;
            }
            this.closeModal('imageModal');
            this.showTyping();
            await new Promise(resolve => setTimeout(resolve, 3000));
            this.hideTyping();
            this.addMessage('assistant', `✓ IMAGE GENERATED\n\nPrompt: "${prompt}"\nModel: ${model}\nStyle: ${style}\n\n[Simulated image would appear here]\n\nIn a production environment, this would generate actual images using the selected model. The image would be displayed above and available for download.`, { name: 'image_generation', model, style, result: 'Image created successfully' });
            document.getElementById('imagePrompt').value = '';
        },

        async executeVideoGeneration() {
            const prompt = document.getElementById('videoPrompt').value;
            const model = document.getElementById('videoModel').value;
            const duration = document.getElementById('videoDuration').value;
            if (!prompt) {
                alert('Please enter a prompt');
                return;
            }
            this.closeModal('videoModal');
            this.addMessage('assistant', `✓ VIDEO GENERATION INITIATED\n\nPrompt: "${prompt}"\nModel: ${model}\nDuration: ${duration}s\n\nProcessing... This typically takes 3-5 minutes. I'll notify you when complete.\n\n[Progress tracking would appear here in production]`, { name: 'video_generation', model, duration, result: 'Generation started' });
            setTimeout(() => {
                this.addMessage('assistant', `✓ VIDEO READY\n\n[Video player would appear here]\n\nYour video has been generated and is ready for download or further editing.`);
            }, 5000);
            document.getElementById('videoPrompt').value = '';
        },

        searchWeb() {
            const input = document.getElementById('messageInput');
            input.value = 'Search for: ';
            input.focus();
        },

        executeCode() {
            const input = document.getElementById('messageInput');
            input.value = 'Execute code: ';
            input.focus();
        },

        useTools() {
            this.addMessage('assistant', `✓ TOOL SELECTOR\n\nAvailable integrations:\n\n📧 Email (Gmail, Outlook)\n📅 Calendar (Google, Apple)\n📁 Cloud Storage (Drive, Dropbox, OneDrive)\n💬 Communication (Slack, Discord, Teams)\n📊 Productivity (Notion, Asana, Trello)\n🗄️ Databases (SQL, MongoDB, PostgreSQL)\n🔗 Custom APIs (REST, GraphQL)\n💻 Developer Tools (GitHub, GitLab)\n\nWhich tool would you like to use?`);
        },

        automate() {
            this.addMessage('assistant', `✓ AUTOMATION BUILDER\n\nI can automate:\n\n• Data pipelines and ETL\n• File synchronization\n• Email workflows\n• Social media posting\n• Report generation\n• Code deployment\n• Backup systems\n• Monitoring and alerts\n• Web scraping\n• API integrations\n\nDescribe your automation needs and I'll build the complete system.`);
        },

        research() {
            this.addMessage('assistant', `✓ DEEP RESEARCH MODE\n\nI'll conduct comprehensive research including:\n\n• Multi-source web search\n• Academic paper analysis\n• Industry reports\n• Statistical data\n• Expert opinions\n• Historical context\n• Current trends\n• Future projections\n\nWhat topic should I research? I'll compile a detailed report with citations.`);
        },

        toggleMobileMenu() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.mobile-overlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        },

        closeMobileMenu() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.mobile-overlay');
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
        }
    };

    app.init();
</script>
