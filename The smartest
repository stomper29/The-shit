    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Rajdhani', sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        overflow: hidden;
        position: relative;
    }

    .bg-matrix {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        opacity: 0.08;
        overflow: hidden;
        pointer-events: none;
    }

    .matrix-column {
        position: absolute;
        top: -100%;
        font-family: 'Courier New', monospace;
        font-size: 14px;
        color: var(--accent-primary);
        animation: matrixFall linear infinite;
    }

    @keyframes matrixFall {
        0% { top: -100%; }
        100% { top: 100%; }
    }

    @keyframes glitch {
        0%, 100% { transform: translate(0); }
        20% { transform: translate(-2px, 2px); }
        40% { transform: translate(-2px, -2px); }
        60% { transform: translate(2px, 2px); }
        80% { transform: translate(2px, -2px); }
    }

    .app-container {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 300px 1fr 340px;
        height: 100vh;
        gap: 1px;
        background: var(--border-color);
    }

    @media (max-width: 768px) {
        .app-container {
            grid-template-columns: 1fr;
            grid-template-rows: auto 1fr auto;
        }
        
        .sidebar {
            display: none;
        }
        
        .right-panel {
            display: none;
        }
        
        .chat-header {
            padding: 12px 16px;
        }
        
        .chat-title {
            font-size: 14px;
        }
        
        .model-selector {
            gap: 6px;
        }
        
        .model-btn {
            padding: 6px 10px;
            font-size: 10px;
        }
        
        .messages-container {
            padding: 16px;
            gap: 20px;
        }
        
        .message-avatar {
            width: 36px;
            height: 36px;
            font-size: 16px;
        }
        
        .input-container {
            padding: 12px 16px;
        }
        
        .input-tools {
            padding: 8px 12px;
            gap: 6px;
        }
        
        .tool-icon-btn {
            width: 34px;
            height: 34px;
            font-size: 16px;
        }
        
        textarea {
            padding: 12px;
            font-size: 14px;
            min-height: 60px;
        }
        
